rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is a member of the organization
    function isOrgMember(orgId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data.active == true;
    }
    
    // User profiles - source of truth for org membership
    match /users/{userId} {
      // Users can only read/write their own profile
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Global memberships collection - legacy, kept for backwards compatibility
    match /memberships/{membershipId} {
      // Users can read their own memberships
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      // Users can create their own membership (during org creation)
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      // Users can update their own membership
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
    
    // Organizations
    match /orgs/{orgId} {
      // Only authenticated users can create orgs
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      // Only org members can read org data
      allow read: if isOrgMember(orgId);
      // Only org members can update org data
      allow update: if isOrgMember(orgId);
      
      // Organization members subcollection
      match /members/{userId} {
        // Members can read member list
        allow read: if isOrgMember(orgId);
        // Only org creator can add the first member (themselves)
        allow create: if isAuthenticated() && 
          (request.auth.uid == userId && request.resource.data.role == 'owner');
        // Members with appropriate roles can manage members
        allow update, delete: if isOrgMember(orgId);
      }
      
      // Leads subcollection - only org members can access
      match /leads/{leadId} {
        allow read, write: if isOrgMember(orgId);
      }
      
      // Activities subcollection - only org members can access
      match /activities/{activityId} {
        allow read, write: if isOrgMember(orgId);
      }
    }
    
    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
