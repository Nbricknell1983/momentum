rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOrgMember(orgId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data.active == true;
    }
    
    function getMemberRole(orgId) {
      return get(/databases/$(database)/documents/orgs/$(orgId)/members/$(request.auth.uid)).data.role;
    }
    
    function isOrgManager(orgId) {
      return isOrgMember(orgId) && getMemberRole(orgId) in ['owner', 'admin'];
    }
    
    function isOwnerOrSelf(orgId, resourceUserId) {
      return isOrgMember(orgId) && (
        getMemberRole(orgId) in ['owner', 'admin'] ||
        resourceUserId == request.auth.uid
      );
    }
    
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /memberships/{membershipId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
    
    match /orgs/{orgId} {
      allow create: if isAuthenticated() && request.resource.data.createdBy == request.auth.uid;
      allow read: if isOrgMember(orgId);
      allow update: if isOrgManager(orgId);
      
      match /members/{userId} {
        allow read: if isOrgMember(orgId);
        allow create: if isAuthenticated() && 
          (request.auth.uid == userId && request.resource.data.role == 'owner');
        allow update, delete: if isOrgManager(orgId);
      }
      
      match /leads/{leadId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId) && request.resource.data.userId == request.auth.uid;
        allow update: if isOwnerOrSelf(orgId, resource.data.userId);
        allow delete: if isOrgManager(orgId);
      }
      
      match /leads/{leadId}/conversations/{convoId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
      }
      
      match /leads/{leadId}/history/{historyId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
      }

      match /leads/{leadId}/engineHistory/{runId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update, delete: if false;
      }
      
      match /activities/{activityId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId) && (request.resource.data.userId == request.auth.uid || isOrgManager(orgId));
        allow update: if isOwnerOrSelf(orgId, resource.data.userId) || isOrgManager(orgId);
        allow delete: if isOrgManager(orgId);
      }
      
      match /clients/{clientId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update: if isOwnerOrSelf(orgId, resource.data.userId);
        allow delete: if isOrgManager(orgId);
      }
      
      match /clients/{clientId}/{subcollection=**} {
        allow read, write: if isOrgMember(orgId);
      }

      match /clients/{clientId}/engineHistory/{runId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update, delete: if false;
      }
      
      match /dailyPlans/{planId} {
        allow read, write: if isOrgMember(orgId);
      }
      
      match /tasks/{taskId} {
        allow read, write: if isOrgMember(orgId);
      }
      
      match /actionQueue/{actionId} {
        allow read, write: if isOrgMember(orgId);
      }
      
      match /actionRecommendations/{recId} {
        allow read, write: if isOrgMember(orgId);
      }
      
      match /pairingCodes/{codeId} {
        allow read, write: if isOrgMember(orgId);
      }
      
      match /dailyPlanSnapshots/{snapId} {
        allow read, write: if isOrgMember(orgId);
      }
      
      match /userSettings/{settingsUserId} {
        allow read, write: if isAuthenticated() && request.auth.uid == settingsUserId;
      }
      
      match /rejectedBusinesses/{businessId} {
        allow read, write: if isOrgMember(orgId);
      }

      // org-level settings (automationRules, openclawConfig, gbpConfig, etc.)
      match /settings/{settingId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgManager(orgId);
      }

      // Bullpen internal comms feed
      match /bullpenComms/{commId} {
        allow read: if isOrgMember(orgId);
        allow create: if isOrgMember(orgId);
        allow update, delete: if isOrgManager(orgId);
      }

      // Growth plays per client (stored under org for multi-tenant isolation)
      match /growthPlays/{playId} {
        allow read: if isOrgMember(orgId);
        allow write: if isOrgMember(orgId);
      }

      // Settings change history — written by server (Admin SDK bypasses rules).
      // Managers can read audit trail. No client-side writes or deletes.
      match /settingsHistory/{settingType}/entries/{entryId} {
        allow read: if isOrgManager(orgId);
        allow create: if false; // server-only via Admin SDK
        allow update, delete: if false; // audit log is immutable
      }
    }
    
    match /users/{userId}/settings/{settingId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    match /reports/{reportId} {
      allow read: if true;
      allow write: if false;
    }
    
    match /strategyReports/{reportId} {
      allow read: if true;
      allow write: if false;
    }
    
    // Agent jobs — only backend writes (via Admin SDK); managers can read
    match /orgs/{orgId}/agentJobs/{jobId} {
      allow read: if isOrgMember(orgId) && isManager(orgId);
      allow write: if false; // backend-only via Admin SDK
    }

    // Dead-letter queue — managers can read; no client writes
    match /orgs/{orgId}/agentJobs_deadletter/{jobId} {
      allow read: if isOrgMember(orgId) && isManager(orgId);
      allow write: if false;
    }

    // Engine history subcollection — immutable; managers can read
    match /orgs/{orgId}/leads/{leadId}/engineHistory/{runId} {
      allow read: if isOrgMember(orgId) && isManager(orgId);
      allow create: if false; // backend-only
      allow update, delete: if false;
    }

    match /orgs/{orgId}/clients/{clientId}/engineHistory/{runId} {
      allow read: if isOrgMember(orgId) && isManager(orgId);
      allow create: if false;
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
